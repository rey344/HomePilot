# ⚠️  SECURITY: NEVER commit this file as .env - it must remain ignored by git
# Copy this file to .env and set real values. The .env file is gitignored.
#
# Usage:
#   cp infrastructure/.env.example infrastructure/.env
#   # Edit .env with your actual secrets
#   docker compose -f infrastructure/docker-compose.yml up --build -d

# PostgreSQL credentials
# REQUIRED for docker-compose (no defaults for security)
# Generate strong passwords: openssl rand -base64 32
POSTGRES_USER=homepilot
POSTGRES_PASSWORD=CHANGE_ME_REQUIRED
POSTGRES_DB=homepilot

# Database connection string
# REQUIRED: Must match the Postgres credentials above
DATABASE_URL=postgresql://homepilot:CHANGE_ME_REQUIRED@postgres:5432/homepilot

# For local development without Docker (SQLite):
# DATABASE_URL=sqlite:///./homepilot.db

# CORS origins (comma-separated)
# Adjust for your deployment domains
CORS_ORIGINS=http://localhost:9002,http://localhost:3000

# Frontend API URL
# Change to your production backend URL when deploying
NEXT_PUBLIC_API_URL=http://localhost:9001

# RapidAPI Key for Real Estate Listing Integration (OPTIONAL)
# Get your key from: https://rapidapi.com/hub
# Leave empty to use mock data
RAPIDAPI_KEY=

# Groq API Key (OPTIONAL - uses rule-based mock if not set)
# Get FREE Groq API key: https://console.groq.com/keys
# Fast inference with Llama models - completely free!
GROQ_API_KEY=

# AI Configuration
AI_PROVIDER=groq  # "groq" or "mock" (rule-based fallback)
AI_MODEL=llama-3.3-70b-versatile  # Groq model to use
AI_TEMPERATURE=0.7  # 0.0-1.0, lower = more deterministic
AI_MAX_TOKENS=500   # Maximum tokens in AI response
