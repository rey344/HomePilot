# Copy to .env and set for local dev or production.
# Backend reads these variables (see backend/app/config.py).

# PostgreSQL credentials (change for production!)
POSTGRES_USER=homepilot
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=homepilot

# Database connection string
DATABASE_URL=postgresql://homepilot:changeme_in_production@localhost:5432/homepilot

# For SQLite in tests or local dev without Postgres:
# DATABASE_URL=sqlite:///:memory:

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:9002,http://localhost:3000

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:9001

# RapidAPI Key for Real Estate Listing Integration
# Get your key from: https://rapidapi.com/hub
RAPIDAPI_KEY=your_rapidapi_key_here
